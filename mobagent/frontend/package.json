    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^24.0.12",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.30.1",
    "eslint-plugin-vue": "^10.3.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.10"
